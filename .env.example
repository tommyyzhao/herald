# Herald — copy to .env.local (gitignored) and fill in. Shared across core/
# and every module; module-specific values (like X_COOKIES_PATH) live here
# too rather than a per-module env file, so there's one place to look.

# Discord bot token. Create an app + bot at https://discord.com/developers/applications,
# invite it to your server, and enable the "Message Content" privileged
# gateway intent (Bot tab) — the listener needs it to read messages.
DISCORD_BOT_TOKEN=

# Your Discord user ID (enable Developer Mode in Discord settings, then
# right-click your name -> Copy User ID). The listener only answers messages
# from this user, regardless of which channel/thread they're posted in.
DISCORD_DM_USER_ID=your-discord-user-id-here

# The channel Herald posts to and listens on (right-click the channel -> Copy
# Channel ID). Threads created off any message in this channel are watched
# too. Leave blank to fall back to DMing DISCORD_DM_USER_ID directly — note
# Discord DMs can't spawn threads, so the thread-reply feature needs a channel.
DISCORD_CHANNEL_ID=

# x-briefs module: twikit cookie file (regenerate with
# `uv run modules/x-briefs/bin/set-cookies.sh` or `login.py` when it 401s).
X_COOKIES_PATH=.secrets/x-twikit-cookies.json
