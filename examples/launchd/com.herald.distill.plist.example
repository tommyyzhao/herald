<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.herald.distill</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/path/to/herald/modules/x-briefs/bin/run-distill.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/herald/modules/x-briefs</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/YOUR_USERNAME</string>
        <key>PATH</key>
        <string>/Users/YOUR_USERNAME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Fire at every HH:00 and HH:30, clock-aligned. Adjust to taste. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Minute</key><integer>0</integer></dict>
        <dict><key>Minute</key><integer>30</integer></dict>
    </array>

    <key>StandardOutPath</key>
    <string>/path/to/herald/modules/x-briefs/logs/launchd-distill.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/herald/modules/x-briefs/logs/launchd-distill.log</string>
</dict>
</plist>
